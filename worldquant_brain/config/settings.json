{
  "project": {
    "name": "WorldQuant BRAIN 量化研究",
    "version": "1.0.0",
    "description": "基于WorldQuant BRAIN平台的量化研究项目"
  },
  "paths": {
    "data_raw": "data/raw",
    "data_processed": "data/processed",
    "datasets": "data/datasets",
    "outputs": "data/outputs",
    "factor_library": "factor_library",
    "knowledge_base": "knowledge_base",
    "scripts": "scripts"
  },
  "mining": {
    "default_region": "USA",
    "default_universe": "TOP1000",
    "min_sharpe_step1": 0.7,
    "min_sharpe_step2": 0.7,
