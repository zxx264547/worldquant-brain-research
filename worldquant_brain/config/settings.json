  "scoring": {
    "d1_weight": 0.30,
    "d2_weight": 0.25,
    "d3_weight": 0.20,
    "d4_weight": 0.25,
    "window_short": 126,
    "window_long": 504
  },
  "os_strategy": {
    "os_threshold": 0.5,
    "check_interval_hours": 4
  }
}
